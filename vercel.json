{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "bash apps/web/vercel-install.sh",
  "buildCommand": "bash apps/web/vercel-build.sh",
  "outputDirectory": "apps/web/dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://129.151.164.101:3001/api/:path*"
    },
    {
      "source": "/marketplace/:path*",
      "destination": "http://129.151.164.101:3001/marketplace/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
