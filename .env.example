# Arc testnet (chain 5042002)
# Prefer arc-canteen RPC after `npm run arc:login` (also sets RPC in shell)
ARC_TESTNET_RPC=https://rpc.testnet.arc.network
RPC=
ARC_CHAIN_ID=5042002

# x402 seller wallet (receives marketplace agent payments) — fund via https://faucet.circle.com
BUTLER_SELLER_ADDRESS=0x0000000000000000000000000000000000000000

# Optional server-side payer (x402 fallback when Circle CLI session is unavailable)
BUTLER_EXECUTOR_PRIVATE_KEY=0x

# Circle CLI payer — prefer dashboard Circle login (email OTP); optional .env override
CIRCLE_EXECUTOR_ADDRESS=
CIRCLE_CHAIN=ARC-TESTNET
BUTLER_USE_CIRCLE_CLI=false
CIRCLE_ACCEPT_TERMS=1

# Circle Gateway (testnet)
GATEWAY_FACILITATOR_URL=https://gateway-api-testnet.circle.com

# Research service (powers analyst agents: thesis, news, reports, audits)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=25000

# Optional task brief passed to merchants by the CLI agent
BUTLER_TASK_BRIEF=
API_PORT=3001
BUTLER_API_URL=http://127.0.0.1:3001
# On production VM with Vercel proxy: public URL for registry + loopback for x402 payments
# BUTLER_API_URL=https://getbutler.xyz
# BUTLER_INTERNAL_AGENT_PAY=false  # default: on — built-in agents run in-process on loopback (avoids Circle CLI deadlock)
WEB_PORT=5174
WEB_URL=http://localhost:5174
VITE_API_URL=http://localhost:3001
VITE_ARC_RPC=

# ─── Open internet agent registry (x402) ───
# On first start, config/external-agents.seed.json → .data/external-agents.json (Arc merchants + Butler agents)
# Or copy config/external-agents.example.json → .data/external-agents.json
# BUTLER_EXTERNAL_REGISTRY_PATH=.data/external-agents.json
# Comma-separated x402 URLs auto-loaded on API start (probed for price)
# BUTLER_EXTERNAL_AGENT_URLS=
# Ephemeral discovery URLs probed during Butler runs (not saved)
# BUTLER_DISCOVERY_URLS=
# Restrict payment to these domains (empty = allow all HTTPS hosts)
# BUTLER_EXTERNAL_DOMAINS_ALLOWLIST=localhost,127.0.0.1
# Max USDC per external agent payment
BUTLER_EXTERNAL_MAX_PRICE_USDC=0.25
# Starting reputation for unproven external agents (auction min is 70)
BUTLER_EXTERNAL_BASELINE_REPUTATION=72
# Set true to enable open-URL discovery in Butler (off by default for security)
# BUTLER_OPEN_DISCOVERY=false
# Require explicit approval before agents can bid or receive payment (default on)
# BUTLER_REQUIRE_AGENT_APPROVAL=true  # default: off — all built-in agents are live for every user
# BUTLER_AGENT_APPROVALS_PATH=.data/agent-approvals.json
# Require x402 probe pass before paying external agents
BUTLER_EXTERNAL_REQUIRE_X402=true

# Gateway trace API (defaults to GATEWAY_FACILITATOR_URL)
GATEWAY_API=
